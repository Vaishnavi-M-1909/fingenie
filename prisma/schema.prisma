generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  avatarUrl            String?
  createdAt            DateTime              @default(now()) @map("created_at")
  statements           Statement[]
  transactions         Transaction[]
  insights             Insight[]
  chats                Chat[]
  bankAccounts         BankAccount[]
  resourceInteractions ResourceInteraction[]

  @@map("users")
}

model Chat {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      String   // user | assistant
  content         String
  imageUrl        String?  @map("image_url")
  recommendations Json?
  createdAt       DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_messages")
}

model BankAccount {
  id                String      @id @default(cuid())
  userId            String      @map("user_id")
  accountHolderName String      @map("account_holder_name")
  accountNumber     String      @map("account_number")
  ifscCode          String?     @map("ifsc_code")
  bankName          String      @map("bank_name")
  branch            String?
  createdAt         DateTime    @default(now()) @map("created_at")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  statements        Statement[]

  @@unique([userId, accountNumber])
  @@index([userId])
  @@map("bank_accounts")
}

model Statement {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  filePath         String        @map("file_path")
  originalFilename String        @map("original_filename")
  uploadedAt       DateTime      @default(now()) @map("uploaded_at")
  status           String        @default("queued") // queued | parsing | done | failed
  meta             Json?
  bankAccountId    String?       @map("bank_account_id")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount      BankAccount?  @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  transactions     Transaction[]
  insights         Insight[]

  @@index([userId])
  @@index([bankAccountId])
  @@map("statements")
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  statementId String?   @map("statement_id")
  date        DateTime
  merchant    String
  amount      Float
  currency    String    @default("INR")
  category    String?
  description String?
  rawLine     String    @map("raw_line")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  statement   Statement? @relation(fields: [statementId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([statementId])
  @@map("transactions")
}

model Insight {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  statementId     String?  @map("statement_id")
  month           String   // e.g. "2026-03"
  score           Int?
  summary         String
  recommendations Json?    // list of {title, url}
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  statement       Statement? @relation(fields: [statementId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([month])
  @@map("insights")
}

model MerchantMap {
  id             String @id @default(cuid())
  normalizedName String @unique @map("normalized_name")
  category       String
  createdBy      String @default("system") @map("created_by") // "system" | userId

  @@map("merchant_maps")
}

model LearningResource {
  id           String                @id @default(cuid())
  title        String
  description  String
  type         String                // VIDEO | ARTICLE | BOOK
  category     String                // Tax, Finance, Spending, Investing, Budgeting, Insurance, Savings
  url          String
  thumbnailUrl String?               @map("thumbnail_url")
  author       String?
  tags         String[]              @default([])
  createdAt    DateTime              @default(now()) @map("created_at")
  interactions ResourceInteraction[]

  @@index([category])
  @@index([type])
  @@map("learning_resources")
}

model ResourceInteraction {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  resourceId   String           @map("resource_id")
  type         String           // CLICK | VIEW | COMPLETE
  interactedAt DateTime         @default(now()) @map("interacted_at")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource     LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceId])
  @@map("resource_interactions")
}
