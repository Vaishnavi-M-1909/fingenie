generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  avatarUrl            String?
  createdAt            DateTime              @default(now()) @map("created_at")
  monthlyReminder      Boolean               @default(false) @map("monthly_reminder")
  bankAccounts         BankAccount[]
  chats                Chat[]
  insights             Insight[]
  resourceInteractions ResourceInteraction[]
  statements           Statement[]
  transactions         Transaction[]

  @@map("users")
}

model Chat {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  role            String
  content         String
  createdAt       DateTime @default(now()) @map("created_at")
  imageUrl        String?  @map("image_url")
  recommendations Json?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_messages")
}

model BankAccount {
  id                String      @id @default(cuid())
  userId            String      @map("user_id")
  accountHolderName String      @map("account_holder_name")
  accountNumber     String      @map("account_number")
  ifscCode          String?     @map("ifsc_code")
  bankName          String      @map("bank_name")
  branch            String?
  createdAt         DateTime    @default(now()) @map("created_at")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  statements        Statement[]

  @@unique([userId, accountNumber])
  @@index([userId])
  @@map("bank_accounts")
}

model Statement {
  id               String        @id @default(cuid())
  userId           String        @map("user_id")
  filePath         String        @map("file_path")
  originalFilename String        @map("original_filename")
  uploadedAt       DateTime      @default(now()) @map("uploaded_at")
  status           String        @default("queued")
  meta             Json?
  bankAccountId    String?       @map("bank_account_id")
  insights         Insight[]
  bankAccount      BankAccount?  @relation(fields: [bankAccountId], references: [id])
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@index([userId])
  @@index([bankAccountId])
  @@map("statements")
}

model Transaction {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  statementId String?    @map("statement_id")
  date        DateTime
  merchant    String
  amount      Float
  currency    String     @default("INR")
  category    String?
  description String?
  rawLine     String     @map("raw_line")
  statement   Statement? @relation(fields: [statementId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([statementId])
  @@map("transactions")
}

model Insight {
  id              String     @id @default(cuid())
  userId          String     @map("user_id")
  statementId     String?    @map("statement_id")
  month           String
  score           Int?
  summary         String
  recommendations Json?
  createdAt       DateTime   @default(now()) @map("created_at")
  statement       Statement? @relation(fields: [statementId], references: [id])
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([month])
  @@map("insights")
}

model MerchantMap {
  id             String @id @default(cuid())
  normalizedName String @unique @map("normalized_name")
  category       String
  createdBy      String @default("system") @map("created_by")

  @@map("merchant_maps")
}

model LearningResource {
  id           String                @id @default(cuid())
  title        String
  description  String
  type         String
  category     String
  url          String
  thumbnailUrl String?               @map("thumbnail_url")
  author       String?
  tags         String[]              @default([])
  createdAt    DateTime              @default(now()) @map("created_at")
  interactions ResourceInteraction[]

  @@index([category])
  @@index([type])
  @@map("learning_resources")
}

model ResourceInteraction {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  resourceId   String           @map("resource_id")
  type         String
  interactedAt DateTime         @default(now()) @map("interacted_at")
  resource     LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceId])
  @@map("resource_interactions")
}
